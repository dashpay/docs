msgid "timestamp"
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid ""
"The current Unix epoch time according to the transmitting node's clock.  "
"Because nodes will reject blocks with timestamps more than two hours in "
"the future, this field can help other nodes to determine that their clock"
" is wrong."
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid "addr_recv services"
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid ""
"*Added in protocol version 106.* <br><br>The services supported by the "
"receiving node as perceived by the transmitting node.  Same format as the"
" 'services' field above. Dash Core will attempt to provide accurate "
"information."
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid "addr_recv IP address"
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid ""
"*Added in protocol version 106.* <br><br>The IPv6 address of the "
"receiving node as perceived by the transmitting node in **big endian byte"
" order**. IPv4 addresses can be provided as [IPv4-mapped IPv6 "
"addresses](http://en.wikipedia.org/wiki/IPv6#IPv4-mapped_IPv6_addresses)."
" Dash Core will attempt to provide accurate information."
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid "addr_recv port"
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid ""
"*Added in protocol version 106.* <br><br>The port number of the receiving"
" node as perceived by the transmitting node in **big endian byte order**."
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid "addr_trans services"
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid ""
"The services supported by the transmitting node.  Should be identical to "
"the 'services' field above."
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid "addr_trans IP address"
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid ""
"The IPv6 address of the transmitting node in **big endian byte order**. "
"IPv4 addresses can be provided as [IPv4-mapped IPv6 "
"addresses](http://en.wikipedia.org/wiki/IPv6#IPv4-mapped_IPv6_addresses)."
"  Set to ::ffff:127.0.0.1 if unknown."
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid "addr_trans port"
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid "The port number of the transmitting node in **big endian byte order**."
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid ""
"A random nonce which can help a node detect a connection to itself.  If "
"the nonce is 0, the nonce field is ignored.  If the nonce is anything "
"else, a node should terminate the connection on receipt of a [`version` "
"message](../reference/p2p-network-control-messages.md#version) with a "
"nonce it previously sent."
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid "user_agent bytes"
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid ""
"Number of bytes in following user\\_agent field.  If 0x00, no user agent "
"field is sent."
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid "user_agent"
msgstr ""

#: ../../docs/core/reference/p2p-network-control-messages.md:397
msgid "Required if user_agent bytes > 0"
