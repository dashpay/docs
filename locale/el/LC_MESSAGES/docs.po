#: ../../docs/core/api/remote-procedure-calls-network.md:513
msgid ""
"[SetNetworkActive](../api/remote-procedure-calls-"
"network.md#setnetworkactive): disables/enables all P2P network activity."
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:122
msgid "[Raw Transaction RPCs](../api/remote-procedure-calls-raw-transactions.md)"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:124
msgid ""
"[AnalyzePSBT](../api/remote-procedure-calls-raw-"
"transactions.md#analyzepsbt): analyzes and provides information about the"
" current status of a PSBT and its inputs. _New in Dash Core 18.2.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:125
msgid ""
"[CombinePSBT](../api/remote-procedure-calls-raw-"
"transactions.md#combinepsbt): combines multiple partially-signed Dash "
"transactions into one transaction. _New in Dash Core 18.0.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:126
msgid ""
"[CombineRawTransaction](../api/remote-procedure-calls-raw-"
"transactions.md#combinerawtransaction): combine multiple partially signed"
" transactions into one transaction. _New in Dash Core 0.15.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:127
msgid ""
"[ConvertToPSBT](../api/remote-procedure-calls-raw-"
"transactions.md#converttopsbt): converts a network serialized transaction"
" to a PSBT. _New in Dash Core 18.0.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:128
msgid ""
"[CreatePSBT](../api/remote-procedure-calls-raw-"
"transactions.md#createpsbt): creates a transaction in the Partially "
"Signed Transaction (PST) format. _New in Dash Core 18.0.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:129
msgid ""
"[GetAssetUnlockStatuses](../api/remote-procedure-calls-raw-"
"transactions.md#getassetunlockstatuses): returns the status of the "
"provided Asset Unlock indexes at the tip of the chain or at a particular "
"block height if specified. _New in Dash Core 20.1.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:130
msgid ""
"[CreateRawTransaction](../api/remote-procedure-calls-raw-"
"transactions.md#createrawtransaction): creates an unsigned serialized "
"transaction that spends a previous output to a new output with a P2PKH or"
" P2SH address. The transaction is not stored in the wallet or transmitted"
" to the network. _Updated in Dash Core 0.17.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:131
msgid ""
"[DecodePSBT](../api/remote-procedure-calls-raw-"
"transactions.md#decodepsbt): returns a JSON object representing the "
"serialized, base64-encoded partially signed Dash transaction. **Updated "
"in Dash Core 23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:132
msgid ""
"[DecodeRawTransaction](../api/remote-procedure-calls-raw-"
"transactions.md#decoderawtransaction): decodes a serialized transaction "
"hex string into a JSON object describing the transaction. **Updated in "
"Dash Core 23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:133
msgid ""
"[DecodeScript](../api/remote-procedure-calls-raw-"
"transactions.md#decodescript): decodes a hex-encoded P2SH redeem script. "
"**Updated in Dash Core 23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:134
msgid ""
"[FinalizePSBT](../api/remote-procedure-calls-raw-"
"transactions.md#finalizepsbt): finalizes the inputs of a PSBT. The PSBT "
"produces a network serialized transaction if the transaction is fully "
"signed. _New in Dash Core 18.0.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:135
msgid ""
"[FundRawTransaction](../api/remote-procedure-calls-raw-"
"transactions.md#fundrawtransaction): adds inputs to a transaction until "
"it has enough in value to meet its out value. **Updated in Dash Core "
"23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:136
msgid ""
"[GetISLocks](../api/remote-procedure-calls-raw-"
"transactions.md#getislocks): returns the raw InstantSend lock data for "
"each provided transaction ID. **Updated in Dash Core 23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:137
msgid ""
"[GetRawTransaction](../api/remote-procedure-calls-raw-"
"transactions.md#getrawtransaction): gets a hex-encoded serialized "
"transaction or a JSON object describing the transaction. By default, Dash"
" Core only stores complete transaction data for UTXOs and your own "
"transactions, so the RPC may fail on historic transactions unless you use"
" the non-default `txindex=1` in your Dash Core startup settings. "
"**Updated in Dash Core 23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:138
msgid ""
"[GetRawTransactionMulti](../api/remote-procedure-calls-raw-"
"transactions.md#getrawtransactionmulti): gets hex-encoded serialized "
"transactions or a JSON object describing the multiple transactions. _New "
"in Dash Core 20.1.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:139
msgid ""
"[GetTxChainlocks](../api/remote-procedure-calls-raw-"
"transactions.md#gettxchainlocks): returns the block height each "
"transaction was mined at and whether it is ChainLocked or not. _Updated "
"in Dash Core 20.1.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:140
msgid ""
"[GetTxSpendingPrevout](../api/remote-procedure-calls-raw-"
"transactions.md#gettxspendingprevout): scans the mempool to find "
"transactions spending any of the provided outputs. **New in Dash Core "
"23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:141
msgid ""
"[JoinPSBTs](../api/remote-procedure-calls-raw-transactions.md#joinpsbts):"
" joins multiple distinct PSBTs with different inputs and outputs into one"
" PSBT with inputs and outputs from all of the PSBTs."
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:142
msgid ""
"[SendRawTransaction](../api/remote-procedure-calls-raw-"
"transactions.md#sendrawtransaction): validates a transaction and "
"broadcasts it to the peer-to-peer network. _Updated in Dash Core 0.15.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:143
msgid ""
"[SignRawTransactionWithKey](../api/remote-procedure-calls-raw-"
"transactions.md#signrawtransactionwithkey): signs a transaction in the "
"serialized transaction format using private keys provided in the call. "
"_New in Dash Core 0.17.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:144
msgid ""
"[TestMempoolAccept](../api/remote-procedure-calls-raw-"
"transactions.md#testmempoolaccept): returns the results of mempool "
"acceptance tests indicating if raw transaction (serialized, hex-encoded) "
"would be accepted by mempool. _Updated in Dash Core 20.1.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:145
msgid ""
"[UTXOUpdatePSBT](../api/remote-procedure-calls-raw-"
"transactions.md#testmempoolaccept): updates a PSBT with data from output "
"descriptors, UTXOs retrieved from the UTXO set or the mempool. _Updated "
"in Dash Core 18.1.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:147
msgid "[Utility RPCs](../api/remote-procedure-calls-util.md)"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:149
msgid ""
"[CreateMultiSig](../api/remote-procedure-calls-util.md#createmultisig): "
"creates a P2SH multi-signature address. _Updated in Dash Core 20.0.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:150
msgid ""
"[DeriveAddresses](../api/remote-procedure-calls-util.md#deriveaddresses):"
" derives one or more addresses corresponding to an output descriptor. "
"_Updated in Dash Core 18.1.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:151
msgid ""
"[EstimateSmartFee](../api/remote-procedure-calls-"
"util.md#estimatesmartfee): estimates the transaction fee per kilobyte "
"that needs to be paid for a transaction to begin confirmation within a "
"certain number of blocks and returns the number of blocks for which the "
"estimate is valid. _Updated in Dash Core 0.15.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:152
msgid ""
"[GetDescriptorInfo](../api/remote-procedure-calls-"
"util.md#getdescriptorinfo): analyses a descriptor. _New in Dash Core "
"18.0.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:153
msgid ""
"[GetIndexInfo](../api/remote-procedure-calls-util.md#getindexinfo): "
"returns the status of one or all available indices currently running in "
"the node. _New in Dash Core 20.0.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:154
msgid ""
"[SignMessageWithPrivKey](../api/remote-procedure-calls-"
"util.md#signmessagewithprivkey): signs a message with a given private "
"key.  _New in Dash Core 0.12.3_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:155
msgid ""
"[ValidateAddress](../api/remote-procedure-calls-util.md#validateaddress):"
" returns information about the given Dash address. _Updated in Dash Core "
"20.1.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:156
#: ../../docs/core/api/remote-procedure-calls-util.md:315
#: ../../docs/core/api/remote-procedure-calls-wallet.md:3509
msgid ""
"[VerifyMessage](../api/remote-procedure-calls-util.md#verifymessage): "
"verifies a signed message."
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:158
msgid "[Wallet RPCs](../api/remote-procedure-calls-wallet.md)"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:160
#: ../../docs/core/api/remote-procedure-call-quick-reference.md:233
msgid ""
"**Note:** the wallet RPCs are only available if Dash Core was built with "
"[wallet support](../resources/glossary.md#wallet-support), which is the "
"default."
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:162
msgid ""
"[AbandonTransaction](../api/remote-procedure-calls-"
"wallet.md#abandontransaction): marks an in-wallet transaction and all its"
" in-wallet descendants as abandoned. This allows their inputs to be "
"respent."
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:163
msgid ""
"[AbortRescan](../api/remote-procedure-calls-wallet.md#abortrescan): stops"
" current wallet rescan. _New in Dash Core 0.15.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:164
msgid ""
"[AddMultiSigAddress](../api/remote-procedure-calls-"
"wallet.md#addmultisigaddress): adds a P2SH multisig address to the "
"wallet. _Updated in Dash Core 20.0.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:165
#: ../../docs/core/api/remote-procedure-calls-wallet.md:389
msgid ""
"[BackupWallet](../api/remote-procedure-calls-wallet.md#backupwallet): "
"safely copies `wallet.dat` to the specified file, which can be a "
"directory or a path with filename."
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:166
msgid ""
"[CreateWallet](../api/remote-procedure-calls-wallet.md#createwallet): "
"creates and loads a new wallet. _Updated in Dash Core 21.0.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:167
msgid ""
"[DumpHDInfo](../api/remote-procedure-calls-wallet.md#dumphdinfo): returns"
" an object containing sensitive private info about this HD wallet New in "
"Dash Core 0.12.2"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:168
#: ../../docs/core/api/remote-procedure-calls-wallet.md:1426
msgid ""
"[DumpPrivKey](../api/remote-procedure-calls-wallet.md#dumpprivkey): "
"returns the wallet-import-format (WIP) private key corresponding to an "
"address. (But does not remove it from the wallet.)"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:169
msgid ""
"[DumpWallet](../api/remote-procedure-calls-wallet.md#dumpwallet): creates"
" or overwrites a file with all wallet keys in a human-readable format. "
"_Updated in Dash Core 0.17.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:170
#: ../../docs/core/api/remote-procedure-calls-wallet.md:3856
#: ../../docs/core/api/remote-procedure-calls-wallet.md:3916
#: ../../docs/core/api/remote-procedure-calls-wallet.md:3962
msgid ""
"[EncryptWallet](../api/remote-procedure-calls-wallet.md#encryptwallet): "
"encrypts the wallet with a passphrase.  This is only to enable encryption"
" for the first time. After encryption is enabled, you will need to enter "
"the passphrase to use private keys."
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:171
msgid ""
"[GetAddressInfo](../api/remote-procedure-calls-wallet.md#getaddressinfo):"
" returns information about the given Dash address. **Updated in Dash Core"
" 23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:172
msgid ""
"[GetAddressesByLabel](../api/remote-procedure-calls-"
"wallet.md#getaddressesbylabel): returns a list of every address assigned "
"to a particular label. _New in Dash Core 0.17.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:173
msgid ""
"[GetBalance](../api/remote-procedure-calls-wallet.md#getbalance): gets "
"the balance in decimal dash across all accounts or for a particular "
"account. _Updated in Dash Core 18.1.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:174
msgid ""
"[GetBalances](../api/remote-procedure-calls-wallet.md#getbalances): "
"returns an object with all balances denominated in DASH. _Updated in Dash"
" Core 18.2.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:175
msgid ""
"[GetNewAddress](../api/remote-procedure-calls-wallet.md#getnewaddress): "
"returns a new Dash address for receiving payments. If an account is "
"specified, payments received with the address will be credited to that "
"account. _Updated in Dash Core 0.17.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:176
#: ../../docs/core/api/remote-procedure-calls-wallet.md:745
msgid ""
"[GetRawChangeAddress](../api/remote-procedure-calls-"
"wallet.md#getrawchangeaddress): returns a new Dash address for receiving "
"change. This is for use with raw transactions, not normal use."
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:177
msgid ""
"[GetReceivedByAddress](../api/remote-procedure-calls-"
"wallet.md#getreceivedbyaddress): returns the total amount received by the"
" specified address in transactions with the specified number of "
"confirmations. It does not count coinbase transactions. **Updated in Dash"
" Core 23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:178
msgid ""
"[GetReceivedByLabel](../api/remote-procedure-calls-"
"wallet.md#getreceivedbylabel): returns the list of addresses assigned the"
" specified label. **Updated in Dash Core 23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:179
msgid ""
"[GetTransaction](../api/remote-procedure-calls-wallet.md#gettransaction):"
" gets detailed information about an in-wallet transaction. **Updated in "
"Dash Core 23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:180
#: ../../docs/core/api/remote-procedure-calls-address-index.md:56
msgid ""
"[GetUnconfirmedBalance](../api/remote-procedure-calls-"
"wallet.md#getunconfirmedbalance): returns the wallet's total unconfirmed "
"balance."
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:181
msgid ""
"[GetWalletInfo](../api/remote-procedure-calls-wallet.md#getwalletinfo): "
"provides information about the wallet.  _Updated in Dash Core 20.0.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:182
#: ../../docs/core/api/remote-procedure-calls-util.md:376
#: ../../docs/core/api/remote-procedure-calls-wallet.md:542
#: ../../docs/core/api/remote-procedure-calls-wallet.md:1374
#: ../../docs/core/api/remote-procedure-calls-wallet.md:1427
#: ../../docs/core/api/remote-procedure-calls-wallet.md:1518
msgid ""
"[ImportAddress](../api/remote-procedure-calls-wallet.md#importaddress): "
"adds an address or pubkey script to the wallet without the associated "
"private key, allowing you to watch for transactions affecting that "
"address or pubkey script without being able to spend any of its outputs."
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:183
msgid ""
"[ImportElectrumWallet](../api/remote-procedure-calls-"
"wallet.md#importelectrumwallet): imports keys from an Electrum wallet "
"export file (.csv or .json) New in Dash Core 0.12.1"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:184
msgid ""
"[ImportDescriptors](../api/remote-procedure-calls-"
"wallet.md#importdescriptors): imports multiple descriptors into the "
"wallet. _New in Dash Core 21.0.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:185
msgid ""
"[ImportMulti](../api/remote-procedure-calls-wallet.md#importmulti): "
"imports addresses or scripts (with private keys, public keys, or P2SH "
"redeem scripts) and optionally performs the minimum necessary rescan for "
"all imports. _New in Dash Core 0.12.3_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:186
#: ../../docs/core/api/remote-procedure-calls-wallet.md:319
#: ../../docs/core/api/remote-procedure-calls-wallet.md:1203
#: ../../docs/core/api/remote-procedure-calls-wallet.md:1373
#: ../../docs/core/api/remote-procedure-calls-wallet.md:1471
#: ../../docs/core/api/remote-procedure-calls-wallet.md:1519
#: ../../docs/core/api/remote-procedure-calls-wallet.md:1555
#: ../../docs/core/api/remote-procedure-calls-wallet.md:2704
msgid ""
"[ImportPrivKey](../api/remote-procedure-calls-wallet.md#importprivkey): "
"adds a private key to your wallet. The key should be formatted in the "
"wallet import format created by the [`dumpprivkey` RPC](../api/remote-"
"procedure-calls-wallet.md#dumpprivkey)."
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:187
msgid ""
"[ImportPrunedFunds](../api/remote-procedure-calls-"
"wallet.md#importprunedfunds): imports funds without the need of a rescan."
" Meant for use with pruned wallets. _New in Dash Core 0.12.3_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:188
#: ../../docs/core/api/remote-procedure-calls-wallet.md:1428
msgid ""
"[ImportPubKey](../api/remote-procedure-calls-wallet.md#importpubkey): "
"imports a public key (in hex) that can be watched as if it were in your "
"wallet but cannot be used to spend"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:189
#: ../../docs/core/api/remote-procedure-calls-wallet.md:169
#: ../../docs/core/api/remote-procedure-calls-wallet.md:390
#: ../../docs/core/api/remote-procedure-calls-wallet.md:1375
#: ../../docs/core/api/remote-procedure-calls-wallet.md:1429
#: ../../docs/core/api/remote-procedure-calls-wallet.md:1520
msgid ""
"[ImportWallet](../api/remote-procedure-calls-wallet.md#importwallet): "
"imports private keys from a file in wallet dump file format (see the "
"[`dumpwallet` RPC](../api/remote-procedure-calls-wallet.md#dumpwallet)). "
"These keys will be added to the keys currently in the wallet.  This call "
"may need to rescan all or parts of the block chain for transactions "
"affecting the newly-added keys, which may take several minutes."
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:190
#: ../../docs/core/api/remote-procedure-calls-wallet.md:2668
msgid ""
"[KeyPoolRefill](../api/remote-procedure-calls-wallet.md#keypoolrefill): "
"fills the cache of unused pre-generated keys (the keypool)."
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:191
msgid ""
"[ListAddressBalances](../api/remote-procedure-calls-"
"wallet.md#listaddressbalances): lists addresses of this wallet and their "
"balances _New in Dash Core 0.12.3_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:192
msgid ""
"[ListAddressGroupings](../api/remote-procedure-calls-"
"wallet.md#listaddressgroupings): lists groups of addresses that may have "
"had their common ownership made public by common use as inputs in the "
"same transaction or from being used as change from a previous "
"transaction. _Updated in Dash Core 0.17.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:193
msgid ""
"[ListDescriptors](../api/remote-procedure-calls-"
"wallet.md#listdescriptors): lists descriptors imported into a descriptor-"
"enabled wallet. **Updated in Dash Core 23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:194
msgid ""
"[ListLabels](../api/remote-procedure-calls-wallet.md#listlabels): returns"
" the list of all labels, or labels that are assigned to addresses with a "
"specific purpose. _New in Dash Core 0.17.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:195
#: ../../docs/core/api/remote-procedure-calls-wallet.md:2632
msgid ""
"[ListLockUnspent](../api/remote-procedure-calls-"
"wallet.md#listlockunspent): returns a list of temporarily unspendable "
"(locked) outputs."
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:196
msgid ""
"[ListReceivedByAddress](../api/remote-procedure-calls-"
"wallet.md#listreceivedbyaddress): lists the total number of dash received"
" by each address. **Updated in Dash Core 23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:197
msgid ""
"[ListReceivedByLabel](../api/remote-procedure-calls-"
"wallet.md#listreceivedbylabel): lists the total number of dash received "
"by each label. **Updated in Dash Core 23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:198
msgid ""
"[ListSinceBlock](../api/remote-procedure-calls-wallet.md#listsinceblock):"
" gets all transactions affecting the wallet which have occurred since a "
"particular block, plus the header hash of a block at a particular depth. "
"_Updated in Dash Core 20.0.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:199
msgid ""
"[ListTransactions](../api/remote-procedure-calls-"
"wallet.md#listtransactions): returns the most recent transactions that "
"affect the wallet. **Updated in Dash Core 23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:200
msgid ""
"[ListUnspent](../api/remote-procedure-calls-wallet.md#listunspent): "
"returns an array of unspent transaction outputs belonging to this wallet."
" **Updated in Dash Core 23.0.0**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:201
msgid ""
"[ListWalletDir](../api/remote-procedure-calls-wallet.md#listwalletdir): "
"returns a list of wallets in the wallet directory. _New in Dash Core "
"18.0.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:202
msgid ""
"[ListWallets](../api/remote-procedure-calls-wallet.md#listwallets): "
"returns a list of currently loaded wallets. _New in Dash Core 0.15.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:203
msgid ""
"[LoadWallet](../api/remote-procedure-calls-wallet.md#loadwallet): loads a"
" wallet from a wallet file or directory. _Updated in Dash Core 18.1.0_"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:204
msgid ""
"[LockUnspent](../api/remote-procedure-calls-wallet.md#lockunspent): "
"temporarily locks or unlocks specified transaction outputs. A locked "
"transaction output will not be chosen by automatic coin selection when "
"spending dash. Locks are stored in memory only, so nodes start with zero "
"locked outputs and the locked output list is always cleared when a node "
"stops or fails. **_Updated in Dash Core 22.1.0_**"
msgstr ""

#: ../../docs/core/api/remote-procedure-call-quick-reference.md:205
msgid ""
"[NewKeyPool](../api/remote-procedure-calls-wallet.md#newkeypool): "
"entirely clears and refills the keypool. **New in Dash Core 23.0.0**"
